<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/av_blue" />
        </shape>
    </item>
    <item
        android:left="2dp"
        android:top="8dp"
        android:right="2dp"
        android:bottom="8dp">
        <shape android:shape="rectangle">
            <stroke android:width="2dp" android:color="@color/av_light_blue" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
</layer-list>
