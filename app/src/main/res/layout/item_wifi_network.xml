<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="8dp"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/imageViewWifiIcon"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/ic_wifi"
        android:contentDescription="Wi-Fi Icon" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/textViewNetworkName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Network Name"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textViewConnected"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Connected"
            android:textColor="@color/av_light_blue"
            android:textSize="12sp"
            android:visibility="gone"
            android:paddingTop="2dp" />
    </LinearLayout>

    <ImageView
        android:id="@+id/imageViewCheck"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/ic_check"
        android:contentDescription="Connected Check"
        android:visibility="gone"
        android:tint="@color/av_light_blue" />

</LinearLayout>
