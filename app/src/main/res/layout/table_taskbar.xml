<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:background="@color/av_darkest_blue"
    android:layout_height="wrap_content"
    android:orientation="horizontal">

    <LinearLayout
        android:id="@+id/lnrSortByName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/table_taskbar_icons_padding"
        android:clickable="true"
        android:focusable="true">

        <ImageButton
            android:id="@+id/imgSoryByName"
            android:layout_width="@dimen/button_image_sm_width"
            android:layout_height="@dimen/button_image_sm_height"
            android:background="@drawable/av_btn_alt"
            android:contentDescription="@string/facility_descending_alphabetical"
            android:scaleType="centerInside"
            app:srcCompat="@drawable/button_alphabetic_active"
            android:focusable="false"
            android:clickable="false"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/facility_descending_alphabetical"
            android:textAlignment="center"
            android:textColor="@color/white"
            android:textSize="@dimen/bottom_bar_button_label"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/lnrSortByDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/table_taskbar_icons_padding"
        android:clickable="true"
        android:focusable="true">

        <ImageButton
            android:id="@+id/imgSotyByDate"
            android:layout_width="@dimen/button_image_sm_width"
            android:layout_height="@dimen/button_image_sm_height"
            android:background="@drawable/av_btn_alt"
            android:contentDescription="@string/cont_desc_vert_offset"
            android:scaleType="centerInside"
            app:srcCompat="@drawable/button_bydate_active"
            android:focusable="false"
            android:clickable="false"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/facility_recent"
            android:textAlignment="center"
            android:textColor="@color/white"
            android:textSize="@dimen/bottom_bar_button_label"
            android:gravity="center"
            android:textStyle="bold"
            />
    </LinearLayout>
</LinearLayout>
