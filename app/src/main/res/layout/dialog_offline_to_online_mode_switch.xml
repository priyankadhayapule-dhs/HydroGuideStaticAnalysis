<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="32dp"
    android:background="@color/white">

    <!-- Header Description -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enter your cloud credentials to switch to Online mode.\nYour offline data will be synced to the cloud."
        android:textSize="16sp"
        android:textColor="@color/av_darkest_blue"
        android:layout_marginBottom="20dp" />

    <!-- Network Status -->
    <TextView
        android:id="@+id/status_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Checking internet connection..."
        android:textSize="14sp"
        android:textColor="@color/av_gray"
        android:layout_marginBottom="20dp"
        android:gravity="center" />

    <!-- Cloud Email Input -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cloud Email"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/av_darkest_blue"
        android:layout_marginBottom="8dp"
        android:layout_marginTop="12dp" />

    <EditText
        android:id="@+id/cloud_email_input"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:hint="Enter your cloud email"
        android:inputType="textEmailAddress"
        android:textSize="16sp"
        android:paddingHorizontal="16dp"
        android:layout_marginBottom="16dp"
        android:background="@android:drawable/editbox_background" />

    <!-- Cloud Password Input -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cloud Password"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/av_darkest_blue"
        android:layout_marginBottom="8dp"
        android:layout_marginTop="12dp" />

    <EditText
        android:id="@+id/cloud_password_input"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:hint="Enter your cloud password"
        android:inputType="textPassword"
        android:textSize="16sp"
        android:paddingHorizontal="16dp"
        android:paddingEnd="50dp"
        android:layout_marginBottom="20dp"
        android:background="@android:drawable/editbox_background"
        android:drawableEnd="@drawable/ic_eye_closed" />

    <!-- Terms and Conditions Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp">

        <CheckBox
            android:id="@+id/terms_checkbox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="I acknowledge that my offline data will be synced to the cloud and I accept the terms and conditions."
            android:textSize="12sp"
            android:textColor="@color/av_darkest_blue"
            android:layout_marginStart="8dp"
            android:layout_gravity="center_vertical" />
    </LinearLayout>

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:visibility="gone" />

    <!-- Warning Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="@drawable/bg_warning_banner"
        android:layout_marginTop="12dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚠️ Important:"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/av_darkest_blue"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="• Internet connection is required\n• All offline data will be synced\n• You will be logged out after successful sync\n• Use your cloud credentials to log back in"
            android:textSize="11sp"
            android:textColor="@color/av_darkest_blue"
            android:lineSpacingMultiplier="1.3" />
    </LinearLayout>

</LinearLayout>
