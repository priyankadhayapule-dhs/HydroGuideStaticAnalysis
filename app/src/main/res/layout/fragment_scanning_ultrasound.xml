<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="title"
            type="String" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/app_background"
        tools:context=".ui.ScanningUltrasoundFragment">

        <include
        android:id="@+id/top_bar"
        layout="@layout/generic_top_bar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/top_bar_height"
        app:title="@{title}"
        app:layout_constraintTop_toTopOf="parent" />

        <!-- Top-left controls: Depth, Gain, Center Line in a card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/ultrasound_controls_card"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="6dp"
            android:layout_marginStart="@dimen/ultrasound_controls_margin_start"
            android:layout_marginTop="@dimen/ultrasound_controls_margin_top"
            app:layout_constraintTop_toBottomOf="@id/top_bar"
            app:layout_constraintStart_toStartOf="parent">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/av_darkest_blue"
                android:padding="@dimen/ultrasound_controls_padding">
                <!-- Depth Control -->
                <LinearLayout
                    android:id="@+id/depth_control"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="@dimen/ultrasound_control_min_size"
                    android:minHeight="@dimen/ultrasound_control_min_size"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:background="@drawable/ultrasound_depth"
                    android:layout_marginEnd="@dimen/ultrasound_control_margin_end"
                    android:paddingTop="@dimen/ultrasound_control_padding_vertical"
                    android:paddingBottom="@dimen/ultrasound_control_padding_vertical">
                    <ImageView
                        android:id="@+id/depth_icon"
                        android:layout_width="45dp"
                        android:layout_height="45dp"
                        android:src="@drawable/ultrasound_control_depth_icon"
                        android:contentDescription="Depth Icon" />
                    <TextView
                        android:id="@+id/depth_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1cm Depth"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:gravity="center_horizontal"
                        android:layout_marginTop="8dp" />
                </LinearLayout>
                <!-- Gain Control -->
                <LinearLayout
                    android:id="@+id/gain_control"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="@dimen/ultrasound_control_min_size"
                    android:minHeight="@dimen/ultrasound_control_min_size"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:background="@drawable/ultrasound_depth"
                    android:layout_marginEnd="@dimen/ultrasound_control_margin_end"
                    android:paddingTop="@dimen/ultrasound_control_padding_vertical"
                    android:paddingBottom="@dimen/ultrasound_control_padding_vertical">
                    <TextView
                        android:id="@+id/gain_value"
                        android:layout_width="45dp"
                        android:layout_height="45dp"
                        android:text="100%"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:gravity="center" />
                    <TextView
                        android:id="@+id/gain_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Gain"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:gravity="center_horizontal"
                        android:layout_marginTop="8dp" />
                </LinearLayout>
                <!-- Center Line Control -->
                <LinearLayout
                    android:id="@+id/center_line_control"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="@dimen/ultrasound_control_min_size"
                    android:minHeight="@dimen/ultrasound_control_min_size"
                    android:orientation="vertical"
                    android:visibility="visible"
                    android:gravity="center_horizontal"
                    android:background="@drawable/ultrasound_depth"
                    android:layout_marginEnd="@dimen/ultrasound_control_margin_end"
                    android:paddingTop="@dimen/ultrasound_control_padding_vertical"
                    android:paddingBottom="@dimen/ultrasound_control_padding_vertical">
                    <ImageView
                        android:id="@+id/center_line_icon"
                        android:layout_width="45dp"
                        android:layout_height="45dp"
                        android:src="@drawable/ultrasound_control_center_line_icon"
                        android:contentDescription="Center Line Icon" />
                    <TextView
                        android:id="@+id/center_line_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Center Line"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:gravity="center_horizontal"
                        android:layout_marginTop="8dp" />
                </LinearLayout>
                <!-- Zoom Reset Control -->
                <LinearLayout
                    android:id="@+id/zoom_reset_control"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="@dimen/ultrasound_control_min_size"
                    android:minHeight="@dimen/ultrasound_control_min_size"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:background="@drawable/ultrasound_depth"
                    android:paddingTop="@dimen/ultrasound_control_padding_vertical"
                    android:paddingBottom="@dimen/ultrasound_control_padding_vertical">
                    <ImageView
                        android:id="@+id/zoom_reset_icon"
                        android:layout_width="45dp"
                        android:layout_height="45dp"
                        android:src="@android:drawable/ic_menu_zoom"
                        android:contentDescription="Zoom Reset Icon"
                        android:tint="@color/white" />
                    <TextView
                        android:id="@+id/zoom_reset_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reset Zoom"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:gravity="center_horizontal"
                        android:layout_marginTop="8dp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Full-screen Ultrasound Image -->
        <!--<ImageView
            android:id="@+id/ultrasound_image"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ultrasound_sample_image"
            app:layout_constraintTop_toBottomOf="@id/top_bar"
            app:layout_constraintBottom_toTopOf="@id/bottom_bar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintWidth_default="spread"
            app:layout_constraintHeight_default="spread"
            android:adjustViewBounds="true"
            android:minWidth="@dimen/ultrasound_image_min_width"
            android:minHeight="@dimen/ultrasound_image_min_height" />-->

        <!-- FrameLayout wrapper for SurfaceView with border -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/top_bar"
            app:layout_constraintBottom_toTopOf="@id/bottom_bar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Surface holder -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/surface_holder"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <!-- Guideline to simulate negative bottom margin -->
                <!-- 1.20 = 20% overlap beyond bottom -->
                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/bottom_overlap_guide"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    app:layout_constraintGuide_percent="1.4" />

                <!-- Ultrasound container -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/ultrasound_container"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/bottom_overlap_guide"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <SurfaceView
                        android:id="@+id/surfaceView"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <!-- Center Line Overlay - positioned exactly over SurfaceView -->
                    <com.accessvascularinc.hydroguide.mma.ui.CenterLineOverlay
                        android:id="@+id/center_line_overlay_view"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        app:layout_constraintTop_toTopOf="@id/surfaceView"
                        app:layout_constraintBottom_toBottomOf="@id/surfaceView"
                        app:layout_constraintStart_toStartOf="@id/surfaceView"
                        app:layout_constraintEnd_toEndOf="@id/surfaceView"
                        android:visibility="visible" />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Depth ruler overlay -->
                <com.accessvascularinc.hydroguide.mma.ui.RulerView
                    android:id="@+id/ruler_view"
                    android:layout_width="80dp"
                    android:layout_height="0dp"
                    android:background="#80000000"
                    android:visibility="gone"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </FrameLayout>

        <RelativeLayout
            android:id="@+id/bottom_bar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/bottom_bar_height"
            android:background="@color/av_darkest_blue"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <!-- Left side buttons (Home, Volume, Brightness, Mute) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Home Button (Back) -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="5dp">

                    <RelativeLayout
                        android:layout_width="@dimen/button_image_width"
                        android:layout_height="@dimen/button_image_height">

                        <ImageButton
                            android:id="@+id/back_btn"
                            android:layout_width="@dimen/button_image_width"
                            android:layout_height="@dimen/button_image_height"
                            android:background="@drawable/av_btn"
                            android:contentDescription="Back to Connect Ultrasound Screen"
                            android:scaleType="centerInside"
                            app:srcCompat="@drawable/left_back" />
                    </RelativeLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:text="Back"
                        android:textAlignment="center"
                        android:textColor="@color/white"
                        android:textSize="@dimen/bottom_bar_button_label"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Volume Button (hidden) -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:padding="5dp">

                    <ImageButton
                        android:id="@+id/volume_btn"
                        android:layout_width="@dimen/button_image_width"
                        android:layout_height="@dimen/button_image_height"
                        android:background="@drawable/av_btn_alt"
                        android:contentDescription="@string/cont_desc_volume"
                        android:scaleType="centerInside"
                        app:srcCompat="@drawable/button_neutral_volume" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:text="@string/change_volume_label"
                        android:textAlignment="center"
                        android:textColor="@color/white"
                        android:textSize="@dimen/bottom_bar_button_label"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Brightness Button (hidden) -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:padding="5dp">

                    <ImageButton
                        android:id="@+id/brightness_btn"
                        android:layout_width="@dimen/button_image_width"
                        android:layout_height="@dimen/button_image_height"
                        android:background="@drawable/av_btn_alt"
                        android:contentDescription="@string/cont_desc_brightness"
                        android:scaleType="centerInside"
                        app:srcCompat="@drawable/button_neutral_brightness" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:text="@string/change_brightness_label"
                        android:textAlignment="center"
                        android:textColor="@color/white"
                        android:textSize="@dimen/bottom_bar_button_label"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Mute Button (hidden) -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:padding="5dp">

                    <ImageButton
                        android:id="@+id/mute_btn"
                        android:layout_width="@dimen/button_image_width"
                        android:layout_height="@dimen/button_image_height"
                        android:background="@drawable/av_btn"
                        android:contentDescription="@string/cont_desc_mute"
                        android:scaleType="centerInside"
                        app:srcCompat="@drawable/button_neutral_mute" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:text="@string/toggle_mute_label"
                        android:textAlignment="center"
                        android:textColor="@color/white"
                        android:textSize="@dimen/bottom_bar_button_label"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Right side - Next button -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_alignParentEnd="true"
                android:orientation="vertical"
                android:padding="5dp">

                <RelativeLayout
                    android:layout_width="@dimen/button_image_width"
                    android:layout_height="@dimen/button_image_height">

                    <!-- Capture Button -->
                    <ImageButton
                        android:id="@+id/capture_btn"
                        android:layout_width="@dimen/button_image_width"
                        android:layout_height="@dimen/button_image_height"
                        android:background="@drawable/av_btn"
                        android:contentDescription="Capture"
                        android:scaleType="centerInside"
                        app:srcCompat="@drawable/button_neutral_camera"
                        android:visibility="visible" />
                    <!-- Proceed Button (for Bluetooth Pairing Pattern) -->
                    <ImageButton
                        android:id="@+id/proceed_btn"
                        android:layout_width="@dimen/button_image_width"
                        android:layout_height="@dimen/button_image_height"
                        android:background="@drawable/av_btn"
                        android:contentDescription="Proceed"
                        android:scaleType="centerInside"
                        app:srcCompat="@drawable/right_back"
                        android:visibility="gone" />
                </RelativeLayout>

                <TextView
                    android:id="@+id/button_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:text="Capture"
                    android:textAlignment="center"
                    android:textColor="@color/white"
                    android:textSize="@dimen/bottom_bar_button_label"
                    android:textStyle="bold" />
            </LinearLayout>

        </RelativeLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
