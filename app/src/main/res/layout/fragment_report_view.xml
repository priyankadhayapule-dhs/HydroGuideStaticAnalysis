<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="procedureReport"
            type="com.accessvascularinc.hydroguide.mma.model.EncounterData" />

        <variable
            name="TabletState"
            type="com.accessvascularinc.hydroguide.mma.model.TabletState" />

        <variable
            name="controllerState"
            type="com.accessvascularinc.hydroguide.mma.model.ControllerState" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/av_blue"
        tools:context=".ui.ReportViewFragment">

        <include
            android:id="@+id/report_view_top_bar"
            layout="@layout/generic_top_bar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/top_bar_height"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:visibility="gone"/>

        <RelativeLayout
            android:id="@+id/report_top_bar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/top_bar_height"
            android:background="@color/av_darkest_blue"
            android:gravity="end"
            android:paddingHorizontal="20dp"
            android:paddingVertical="10dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/report_view_top_bar">

            <LinearLayout
                android:id="@+id/report_patient_name_grp"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_alignParentStart="true"
                android:layout_marginEnd="@dimen/input_box_margin_end"
                android:layout_toStartOf="@id/report_patient_id_grp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/report_patient_name_label"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="@dimen/input_box_margin_end"
                    android:gravity="center_vertical"
                    android:text="@string/patient_name_input_label"
                    android:textColor="@color/av_light_blue"
                    android:textSize="@dimen/report_view_top_bar_text_size"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/report_patient_name"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:text="@{procedureReport.patient.patientName}"
                    android:textColor="@color/white"
                    android:textSize="@dimen/report_view_top_bar_text_size"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/report_patient_id_grp"
                android:layout_width="450dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="@dimen/input_box_margin_end"
                android:layout_toStartOf="@id/report_date_grp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/report_patient_id_label"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="@dimen/input_box_margin_end"
                    android:gravity="center_vertical"
                    android:text="@string/patient_id_input_label"
                    android:textColor="@color/av_light_blue"
                    android:textSize="@dimen/report_view_top_bar_text_size"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/report_patient_id"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:text="@{procedureReport.patient.patientId}"
                    android:textColor="@color/white"
                    android:textSize="@dimen/report_view_top_bar_text_size"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/report_date_grp"
                android:layout_width="230dp"
                android:layout_height="match_parent"
                android:layout_alignParentEnd="true"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/report_date_label"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="@dimen/input_box_margin_end"
                    android:gravity="center_vertical"
                    android:text="@string/report_date_label"
                    android:textColor="@color/av_light_blue"
                    android:textSize="@dimen/report_view_top_bar_text_size"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/report_date"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:text="@{procedureReport.startTimeShortText}"
                    android:textColor="@color/white"
                    android:textSize="@dimen/report_view_top_bar_text_size"
                    android:textStyle="bold" />
            </LinearLayout>

        </RelativeLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/report_viewer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_margin="10dp"
            android:layout_marginStart="8dp"
            android:baselineAligned="false"
            android:clipToPadding="false"
            android:fadeScrollbars="false"
            android:orientation="vertical"
            android:padding="5dp"
            android:paddingHorizontal="16dp"
            android:scrollbarAlwaysDrawVerticalTrack="true"
            android:scrollbarSize="10dp"
            android:scrollbarStyle="outsideInset"
            android:scrollbarThumbVertical="@color/av_gray"
            android:scrollbarTrackVertical="@color/av_darkest_blue"
            android:scrollbars="vertical"
            app:layout_constraintBottom_toTopOf="@id/report_satisfaction_select"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/report_top_bar">

        </androidx.recyclerview.widget.RecyclerView>

        <LinearLayout
            android:id="@+id/report_satisfaction_select"
            android:layout_width="1050dp"
            android:layout_height="wrap_content"
            android:layout_marginVertical="10dp"
            android:background="@color/av_tip_confirm_yellow"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintBottom_toTopOf="@id/report_view_bottom_bar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/report_viewer">

            <TextView
                android:id="@+id/report_satisfaction_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:gravity="center"
                android:text="@string/report_satisfaction_select_label"
                android:textAlignment="center"
                android:textColor="@color/av_darkest_blue"
                android:textSize="24sp"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/report_satisfaction_radio_group"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/report_satisfaction_yes"
                    style="@style/Widget.App.CheckBox"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_marginHorizontal="10dp"
                    android:text="@string/report_satisfaction_yes"
                    android:textColor="@color/av_darkest_blue"
                    android:textSize="24sp" />

                <RadioButton
                    android:id="@+id/report_satisfaction_no"
                    style="@style/Widget.App.CheckBox"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_marginHorizontal="10dp"
                    android:text="@string/report_satisfaction_no"
                    android:textColor="@color/av_darkest_blue"
                    android:textSize="24sp" />
            </RadioGroup>
        </LinearLayout>


        <RelativeLayout
            android:id="@+id/report_view_bottom_bar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/bottom_bar_height"
            android:background="@color/av_darkest_blue"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/back_button_container"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <ImageButton
                        android:id="@+id/back_button_review"
                        android:layout_width="35dp"
                        android:layout_height="40dp"
                        android:background="@drawable/av_btn"
                        android:scaleType="fitCenter"
                        app:srcCompat="@drawable/select_profile_arrow_left" />


                </LinearLayout>

                <Space
                    android:layout_width="15dp"
                    android:layout_height="match_parent" />

                <LinearLayout
                    android:layout_width="306dp"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/free_byte_label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.5"
                        android:autoSizeTextType="uniform"
                        android:text="@string/storage_remaining_label"
                        android:textColor="@color/av_light_blue"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/free_byte_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:autoSizeTextType="uniform"
                        android:text=""
                        android:textColor="@color/av_light_blue"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/concluded_procedure_indicator"
                android:layout_width="350dp"
                android:layout_height="45dp"
                android:layout_alignParentTop="true"
                android:layout_centerInParent="true"
                android:autoSizeTextType="uniform"
                android:gravity="center"
                android:text="@string/conclusion_signal"
                android:textColor="@color/av_green"
                android:textStyle="bold"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/volume"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="5dp">

                    <ImageButton
                        android:id="@+id/volume_btn"
                        android:layout_width="@dimen/button_image_width"
                        android:layout_height="@dimen/button_image_height"
                        android:background="@drawable/av_btn_alt"
                        android:contentDescription="@string/cont_desc_volume"
                        android:scaleType="centerInside"
                        app:srcCompat="@drawable/button_neutral_volume" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:text="@string/change_volume_label"
                        android:textAlignment="center"
                        android:textColor="@color/white"
                        android:textSize="@dimen/bottom_bar_button_label"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/brightness"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="240dp"
                    android:layout_toEndOf="@id/volume"
                    android:orientation="vertical"
                    android:padding="5dp">

                    <ImageButton
                        android:id="@+id/brightness_btn"
                        android:layout_width="@dimen/button_image_width"
                        android:layout_height="@dimen/button_image_height"
                        android:background="@drawable/av_btn_alt"
                        android:contentDescription="@string/cont_desc_brightness"
                        android:scaleType="centerInside"
                        app:srcCompat="@drawable/button_neutral_brightness" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:text="@string/change_brightness_label"
                        android:textAlignment="center"
                        android:textColor="@color/white"
                        android:textSize="@dimen/bottom_bar_button_label"
                        android:textStyle="bold" />
                </LinearLayout>


                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="end"
                    android:orientation="horizontal">

                    <RelativeLayout
                        android:layout_width="173dp"
                        android:layout_height="match_parent"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/controller_battery_label"
                            android:layout_width="match_parent"
                            android:layout_height="26dp"
                            android:autoSizeTextType="uniform"
                            android:text="@string/controller_battery_label"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/remote_battery_level_indicator"
                            android:layout_width="53dp"
                            android:layout_height="37dp"
                            android:layout_below="@id/controller_battery_label"
                            android:contentDescription="@string/cont_desc_battery_level_display"
                            app:srcCompat="@drawable/indicator_battery_90" />

                        <TextView
                            android:id="@+id/controller_battery_level_pct"
                            android:layout_width="106dp"
                            android:layout_height="37dp"
                            android:layout_below="@id/controller_battery_label"
                            android:layout_alignParentEnd="true"
                            android:autoSizeTextType="uniform"
                            android:text="@{controllerState.batteryLevelPct > -1 ? Integer.toString(Math.round(controllerState.batteryLevelPct)) + '%': `??? `}"
                            android:textColor="@color/av_green" />

                    </RelativeLayout>

                    <RelativeLayout
                        android:layout_width="173dp"
                        android:layout_height="match_parent"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tablet_battery_label"
                            android:layout_width="match_parent"
                            android:layout_height="26dp"
                            android:autoSizeTextType="uniform"
                            android:text="@string/tablet_battery_label"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/tablet_battery_level_indicator"
                            android:layout_width="53dp"
                            android:layout_height="37dp"
                            android:layout_below="@id/tablet_battery_label"
                            android:contentDescription="@string/cont_desc_battery_level_display"
                            app:srcCompat="@drawable/indicator_battery_90" />

                        <TextView
                            android:id="@+id/tablet_battery_level_pct"
                            android:layout_width="106dp"
                            android:layout_height="37dp"
                            android:layout_below="@id/tablet_battery_label"
                            android:layout_alignParentEnd="true"
                            android:autoSizeTextType="uniform"
                            android:text="@{TabletState.tabletChargePct > -1 ? Integer.toString(TabletState.tabletChargePct) + '%': `??? `}"
                            android:textColor="@color/av_green" />

                    </RelativeLayout>

                    <ImageView
                        android:id="@+id/usb_icon"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/cont_desc_usb_icon"
                        app:srcCompat="@drawable/logo_usb_disconnected" />
                </LinearLayout>

                <Space
                    android:layout_width="15dp"
                    android:layout_height="match_parent" />

                <LinearLayout
                    android:id="@+id/home"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="5dp">

                    <ImageButton
                        android:id="@+id/nav_to_home_screen"
                        android:layout_width="@dimen/button_image_width"
                        android:layout_height="@dimen/button_image_height"
                        android:background="@drawable/av_btn"
                        android:contentDescription="@string/cont_desc_return_to_patient_input"
                        android:scaleType="centerInside"
                        app:srcCompat="@drawable/button_report_checkmark" />

                    <TextView
                        android:id="@+id/home_button_label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:text="@string/submit_report"
                        android:textAlignment="center"
                        android:textColor="@color/white"
                        android:textSize="@dimen/bottom_bar_button_label"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </RelativeLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>