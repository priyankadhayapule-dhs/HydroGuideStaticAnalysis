<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="title"
            type="String" />

        <variable
            name="showSyncIcon"
            type="Boolean" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/app_background"
        tools:context=".ui.BluetoothPairingFragment">

        <include
            android:id="@+id/home_top_bar"
            layout="@layout/generic_top_bar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/top_bar_height"
            app:title="@{title}"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Main Content: Move update_found_container to be direct child of outer ConstraintLayout -->
        <LinearLayout
            android:id="@+id/update_found_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="32dp"
            android:paddingTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/home_top_bar"
            app:layout_constraintStart_toStartOf="parent">

            <!-- Package Icon -->
            <ImageView
                android:id="@+id/package_icon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_package"
                android:layout_marginEnd="16dp"
                app:tint="@android:color/white" />

            <!-- Package Name -->
            <TextView
                android:id="@+id/package_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Package_13.01.02_05_10_2025.zip"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:ellipsize="end"
                android:singleLine="true" />

            <!-- Extract Button -->
            <Button
                android:id="@+id/btn_extract"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/extract"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:backgroundTint="@android:color/transparent"
                android:background="@drawable/btn_outline_white"
                android:paddingHorizontal="20dp"
                android:paddingVertical="6dp" />
        </LinearLayout>

        <!-- ========================== -->
        <!-- 2️⃣  EXTRACTING PACKAGE SECTION -->
        <!-- ========================== -->
        <LinearLayout
            android:id="@+id/extracting_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/home_top_bar"
            app:layout_constraintBottom_toTopOf="@id/bottom_bar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/extract_icon"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_package"
                app:tint="@android:color/white" />

            <TextView
                android:id="@+id/extract_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/extracting_package"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:layout_marginTop="16dp" />

            <ProgressBar
                android:id="@+id/progress_bar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="400dp"
                android:layout_height="28dp"
                android:layout_marginTop="32dp"
                android:max="100"
                android:progress="0"
                android:indeterminate="false"
                android:progressDrawable="@drawable/progress_bar_custom" />
        </LinearLayout>

        <!-- 3️⃣ INSTALL PACKAGES SECTION -->
        <LinearLayout
            android:id="@+id/install_packages_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="32dp"
            android:paddingTop="24dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/home_top_bar"
            app:layout_constraintStart_toStartOf="parent">

            <!-- Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_package"
                    app:tint="@android:color/white"
                    android:layout_marginEnd="16dp" />
                <!-- TODO: Hard code file to be replace with actual -->
                <TextView
                    android:id="@+id/app_package_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="App_13.01.02_05_10_2025"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:singleLine="true"
                    android:ellipsize="end" />

                <Button
                    android:id="@+id/btn_install_app"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/install"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:backgroundTint="@android:color/transparent"
                    android:background="@drawable/btn_outline_white"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="6dp" />
            </LinearLayout>

            <!-- Row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:contentDescription="@string/install"
                    android:src="@drawable/ic_package"
                    app:tint="@android:color/white"
                    android:layout_marginEnd="16dp" />

                <!-- TODO: Hard code file to be replace with actual -->
                <TextView
                    android:id="@+id/controller_package_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Controller_13.01.02_05_10_2025"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:singleLine="true"
                    android:ellipsize="end" />

                <Button
                    android:id="@+id/btn_install_controller"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/install"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:backgroundTint="@android:color/transparent"
                    android:background="@drawable/btn_outline_white"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="6dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- 4️⃣ INSTALL PROGRESS SCREEN -->
        <LinearLayout
            android:id="@+id/install_progress_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/home_top_bar"
            app:layout_constraintBottom_toTopOf="@id/bottom_bar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Package Icon -->
            <ImageView
                android:id="@+id/install_icon"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:contentDescription="@string/install"
                android:src="@drawable/ic_install_package"
                app:tint="@android:color/white"
                android:layout_marginBottom="20dp" />

            <!-- Installing Message -->
            <TextView
                android:id="@+id/install_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/installing_app_updates"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:gravity="center"
                android:layout_marginBottom="32dp" />

            <!-- Progress Bar -->
            <ProgressBar
                android:id="@+id/install_progress_bar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="400dp"
                android:layout_height="28dp"
                android:max="100"
                android:progress="0"
                android:indeterminate="false"
                android:progressDrawable="@drawable/progress_bar_custom" />

        </LinearLayout>
        <!-- 5️⃣ INSTALL SUCCESS SCREEN -->
        <LinearLayout
            android:id="@+id/install_success_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/home_top_bar"
            app:layout_constraintBottom_toTopOf="@id/bottom_bar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Success Icon (same install icon) -->
            <ImageView
                android:id="@+id/success_icon"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginBottom="32dp"
                android:src="@drawable/ic_install_package" />

            <!-- Success Message Box -->
            <LinearLayout
                android:id="@+id/success_message_box"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#64FDD4"
                android:paddingHorizontal="24dp"
                android:paddingVertical="12dp"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/success_check_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_check"
                    android:layout_marginEnd="12dp"
                    app:tint="@android:color/black" />

                <TextView
                    android:id="@+id/success_message"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/latest_app_updates_installed_successfully"
                    android:textColor="@android:color/black"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>


        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/bottom_bar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/bottom_bar_height"
            android:background="@color/av_darkest_blue"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <!-- Back section (Left corner) -->
            <LinearLayout
                android:id="@+id/back_section"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="5dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <ImageButton
                    android:id="@+id/back_btn"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/back"
                    android:scaleType="fitCenter"
                    android:src="@drawable/left_back" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="8dp"
                    android:gravity="center"
                    android:text="@string/back"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Retry section (Right corner) -->
            <LinearLayout
                android:id="@+id/retry_section"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="5dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <ImageButton
                    android:id="@+id/retry_btn"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/retry"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_retry" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:gravity="center"
                    android:text="@string/retry"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
