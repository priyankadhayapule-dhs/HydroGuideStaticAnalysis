<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/alert_icon">

    <TextView
        android:layout_width="355dp"
        android:layout_height="60dp"
        android:background="@drawable/simple_red_border"
        android:gravity="start"
        android:text=""
        android:textStyle="bold"
        tools:ignore="MissingConstraints" />

    <TextView
        android:layout_width="355dp"
        android:layout_height="60dp"
        android:background="@drawable/simple_red_border"
        android:backgroundTint="@color/battery_red"
        android:alpha="0.3"
        android:gravity="start"
        android:text=""
        android:textStyle="bold"
        tools:ignore="MissingConstraints" />

    <LinearLayout
        android:id="@+id/missing_controller_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:baselineAligned="false"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/missing_controller_icon"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:padding="6dp"
            android:src="@drawable/warning_icon"
            tools:ignore="MissingConstraints"
            android:gravity="center"/>

        <TextView
            android:id="@+id/missing_controller_text"
            android:text="@string/alert_symbol_ECG_missing_text"
            android:layout_width="290dp"
            android:layout_height="60dp"
            android:textColor="@color/battery_red"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:paddingEnd="6dp"
            android:textAlignment="center"
            android:gravity="center"
            android:textSize="30sp"
            android:textFontWeight="700" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>