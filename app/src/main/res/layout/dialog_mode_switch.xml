<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="32dp"
    android:background="@color/white">

    <!-- Header Description -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Set a temporary password for all clinicians.\nClinicians will be forced to change it on first login."
        android:textSize="16sp"
        android:textColor="@color/av_darkest_blue"
        android:layout_marginBottom="20dp" />

    <!-- Network Status -->
    <TextView
        android:id="@+id/status_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Checking internet connection..."
        android:textSize="14sp"
        android:textColor="@color/av_gray"
        android:layout_marginBottom="20dp"
        android:gravity="center" />

    <!-- Clinician Password Input -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Temporary Clinician Password"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/av_darkest_blue"
        android:layout_marginBottom="8dp"
        android:layout_marginTop="12dp" />

    <EditText
        android:id="@+id/clinician_password_input"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:hint="Enter password (min 6 characters)"
        android:inputType="textPassword"
        android:textSize="16sp"
        android:paddingHorizontal="16dp"
        android:paddingEnd="50dp"
        android:layout_marginBottom="16dp"
        android:background="@android:drawable/editbox_background"
        android:drawableEnd="@drawable/ic_eye_closed" />

    <!-- Confirm Password Input -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Confirm Password"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/av_darkest_blue"
        android:layout_marginBottom="8dp"
        android:layout_marginTop="12dp" />

    <EditText
        android:id="@+id/confirm_password_input"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:hint="Re-enter password"
        android:inputType="textPassword"
        android:textSize="16sp"
        android:paddingHorizontal="16dp"
        android:paddingEnd="50dp"
        android:layout_marginBottom="20dp"
        android:background="@android:drawable/editbox_background"
        android:drawableEnd="@drawable/ic_eye_closed" />

    <!-- Terms and Conditions Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/av_light_blue"
        android:padding="16dp"
        android:layout_marginBottom="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TERMS AND CONDITIONS"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/av_darkest_blue"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="• This tablet will be configured to work in Offline mode.\n• All clinician data and facility information will be downloaded to this device.\n• The temporary password you set will be used for all clinicians on first login.\n• Each clinician must change their password on their first login for security.\n• This action cannot be reversed without administrative intervention.\n• Internet connection is required to perform this operation."
            android:textSize="13sp"
            android:textColor="@color/av_darkest_blue"
            android:lineSpacingExtra="6dp"
            android:layout_marginBottom="16dp" />

        <CheckBox
            android:id="@+id/terms_checkbox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="I accept the terms and conditions"
            android:textSize="14sp"
            android:textColor="@color/av_darkest_blue"
            android:checked="false" />
    </LinearLayout>

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:indeterminate="true"
        android:visibility="gone"
        android:layout_marginVertical="20dp" />

    <!-- Warning Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/av_light_blue"
        android:padding="16dp"
        android:layout_marginVertical="16dp"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_dialog_alert"
            android:tint="@color/battery_red"
            android:layout_marginEnd="12dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Once switched to Offline mode, internet connection will not be required. All clinician data and facilities must be downloaded first."
            android:textSize="13sp"
            android:textColor="@color/av_darkest_blue" />
    </LinearLayout>

</LinearLayout>
