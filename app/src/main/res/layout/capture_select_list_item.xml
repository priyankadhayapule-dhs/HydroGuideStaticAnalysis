<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="40dp"
    android:background="?attr/selectableItemBackground"
    android:minHeight="?attr/minTouchTargetSize"
    android:orientation="horizontal">

    <CheckBox
        android:id="@+id/capture_select_item_checkbox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="0dp"
        android:gravity="center"
        android:minWidth="40dp"
        android:textSize="24sp" />

    <RelativeLayout
        android:layout_width="40dp"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/capture_select_item_icon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_centerInParent="true"
            android:layout_marginStart="0dp"
            android:layout_marginEnd="5dp"
            android:contentDescription="@string/img_desc_capture_select_icon"
            android:padding="2dp"
            android:src="@drawable/logo_capture_internal"
            app:tint="@color/white" />

        <TextView
            android:id="@+id/capture_select_item_number"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_centerHorizontal="true"
            android:gravity="center"
            android:text="@string/intrav_capture_number"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <TextView
        android:id="@+id/capture_select_item_length"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="5dp"
        android:layout_weight="1"
        android:maxLines="1"
        android:textAlignment="textEnd"
        android:textColor="@color/av_light_blue"
        android:textSize="24sp"
        android:textStyle="bold" />

</LinearLayout>