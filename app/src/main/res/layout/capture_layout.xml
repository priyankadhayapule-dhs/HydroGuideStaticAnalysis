<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/capture_layout"
    android:layout_width="400dp"
    android:layout_height="400dp"
    android:layout_marginEnd="10dp"
    android:background="@drawable/border_capture"
    android:orientation="horizontal">

    <ImageView
        android:id="@+id/capture_icon"
        android:layout_width="@dimen/capture_header_footer_height"
        android:layout_height="@dimen/capture_header_footer_height"
        android:layout_marginStart="0dp"
        android:layout_marginEnd="5dp"
        android:contentDescription="@string/img_desc_facility_fav_icon"
        android:padding="2dp"
        android:src="@drawable/logo_capture_internal" />

    <TextView
        android:id="@+id/capture_id"
        android:layout_width="32dp"
        android:layout_height="@dimen/capture_header_footer_height"
        android:gravity="center"
        android:text="@string/intrav_capture_number"
        android:textColor="@color/white"
        android:textSize="@dimen/capture_id_text_size"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/capture_header_label"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/capture_header_footer_height"
        android:layout_toEndOf="@id/capture_icon"
        android:text="@string/capture_header_label"
        android:textColor="@color/black"
        android:textSize="@dimen/capture_text_size"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/capture_inserted_length"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/capture_header_footer_height"
        android:layout_alignParentEnd="true"
        android:layout_marginStart="10dp"
        android:paddingStart="0dp"
        android:paddingEnd="5dp"
        android:text="@string/invalid_length"
        android:textColor="@color/black"
        android:textSize="@dimen/capture_text_size"
        android:textStyle="bold" />

    <com.androidplot.xy.XYPlot
        android:id="@+id/capture_plot_graph"
        style="@style/APDefacto.Dark"
        android:layout_width="match_parent"
        android:layout_height="340dp"
        android:layout_below="@id/capture_header_label"
        android:background="@color/ap_transparent"
        app:backgroundColor="@color/ap_transparent"
        android:layout_marginTop="0dp"
        app:domainStep="0"
        app:domainStepMode="subdivide"
        app:graphBackgroundColor="@color/ap_transparent"
        app:graphHeight="1.0"
        app:graphHeightMode="relative"
        app:graphWidth="1.0"
        app:graphWidthMode="relative"
        app:gridBackgroundColor="@color/ap_transparent"
        app:gridInsetBottom="0dp"
        app:gridInsetLeft="0dp"
        app:legendVisible="false"
        app:lineLabels="none" />

    <TextView
        android:id="@+id/capture_footer_label"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/capture_header_footer_height"
        android:layout_alignParentBottom="true"
        android:layout_toEndOf="@id/capture_icon"
        android:text="@string/intrav_capture_footer_label"
        android:textColor="@color/black"
        android:textSize="@dimen/capture_text_size"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/capture_exposed_length"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/capture_header_footer_height"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="10dp"
        android:paddingStart="0dp"
        android:paddingEnd="5dp"
        android:text="@string/invalid_length"
        android:textColor="@color/black"
        android:textSize="@dimen/capture_text_size"
        android:textStyle="bold" />

</RelativeLayout>