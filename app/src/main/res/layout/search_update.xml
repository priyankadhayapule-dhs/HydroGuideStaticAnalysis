<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">
    <data>
        <variable
            name="title"
            type="String" />
        <variable
            name="showSyncIcon"
            type="Boolean" />
        <variable
            name="profileState"
            type="com.accessvascularinc.hydroguide.mma.model.ProfileState" />
    </data>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/av_blue">

        <LinearLayout
            android:id="@+id/lnrTopbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            tools:layout_editor_absoluteX="0dp"
            tools:layout_editor_absoluteY="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent">

            <include
                android:id="@+id/includeTopbar"
                layout="@layout/generic_top_bar"
                android:layout_width="match_parent"
                android:layout_height="@dimen/top_bar_height"/>

        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recInstallPackages"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:fadeScrollbars="false"
            android:orientation="vertical"
            android:scrollbarAlwaysDrawVerticalTrack="true"
            android:scrollbarSize="@dimen/dimen_10x"
            android:scrollbarStyle="outsideInset"
            android:scrollbarThumbVertical="@color/av_gray"
            android:scrollbarTrackVertical="@color/av_darkest_blue"
            android:scrollbars="vertical"
            android:padding="@dimen/horizontal_padding"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/lnrSoftwareVersionContainer"
            app:layout_constraintTop_toBottomOf="@+id/lnrTopbar"
            app:layout_constraintWidth_percent="0.7"
            app:layout_constraintBottom_toTopOf="@+id/inclBottomBar"
            android:visibility="visible"/>

        <LinearLayout
            android:id="@+id/lnrSoftwareVersionContainer"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintWidth_percent="0.3"
            app:layout_constraintStart_toEndOf="@+id/recInstallPackages"
            app:layout_constraintTop_toBottomOf="@+id/lnrTopbar"
            app:layout_constraintBottom_toTopOf="@+id/inclBottomBar"
            android:padding="@dimen/dimen_16x"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:autoSizeTextType="uniform"
                android:textSize="@dimen/sp_dimen_14x"
                android:text="@string/sys_update_label_current_app_version"
                android:textColor="@color/av_light_blue"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvCurrentAppVersion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="@dimen/sp_dimen_18x"
                android:autoSizeTextType="uniform"
                android:drawablePadding="10dp"
                android:textColor="@color/av_light_blue"
                android:textStyle="bold"
                android:text=""/>

            <TextView
                android:layout_marginTop="@dimen/dimen_16x"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:autoSizeTextType="uniform"
                android:textSize="@dimen/sp_dimen_14x"
                android:text="@string/sys_update_label_current_controller_version"
                android:textColor="@color/av_light_blue"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvCurrentControllerVersion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="@dimen/sp_dimen_18x"
                android:autoSizeTextType="uniform"
                android:drawablePadding="10dp"
                android:textColor="@color/av_light_blue"
                android:textStyle="bold"
                android:text=""/>


            <TextView
                android:layout_marginTop="@dimen/dimen_16x"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:autoSizeTextType="uniform"
                android:textSize="@dimen/sp_dimen_14x"
                android:text="@string/sys_update_label_current_os_version"
                android:textColor="@color/av_light_blue"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvCurrentOsVersion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="@dimen/sp_dimen_18x"
                android:autoSizeTextType="uniform"
                android:drawablePadding="10dp"
                android:textColor="@color/av_light_blue"
                android:textStyle="bold"
                android:text=""/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/lnrProgressContainer"
            orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:baselineAligned="false"
            android:gravity="center"
            android:padding="@dimen/container_layouts_spacing"
            app:layout_constraintTop_toBottomOf="@+id/lnrTopbar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/inclBottomBar"
            app:layout_constraintVertical_bias="0.0">

            <LinearLayout
                android:id="@+id/lnrProgress"
                android:orientation="vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <ProgressBar
                    android:id="@+id/progressBar"
                    style="?android:attr/progressBarStyleLarge"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:indeterminate="true"
                    android:indeterminateTint="@android:color/white" />

                <TextView
                    android:id="@+id/tvProgressMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/searching_updates_online"
                    android:textColor="@android:color/white"
                    android:textSize="@dimen/sp_dimen_18x"
                    android:layout_marginTop="20dp"
                    android:gravity="center" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvNoUpdates"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@color/colr_sys_update_no_updates"
                android:padding="@dimen/dimen_16x"
                android:text="@string/no_latest_updates_found"
                android:textColor="@android:color/black"
                android:textStyle="bold"
                android:textSize="@dimen/sp_dimen_18x"
                android:gravity="center"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:drawableStart="@drawable/ic_retry"
                android:drawablePadding="@dimen/dimen_8x"
                android:visibility="gone"
                />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/lnrProgressInstaller"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:baselineAligned="false"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@+id/lnrTopbar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/inclBottomBar"
            app:layout_constraintVertical_bias="0.0"
            android:visibility="visible">

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Space
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.2" />

                <ProgressBar
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_weight="0.8"
                    android:layout_height="@dimen/bottom_bar_height"
                    android:indeterminate="true"
                    android:max="100"
                    android:progress="0"
                    android:indeterminateTintMode="src_atop"
                    android:indeterminateTint="@color/color_progess_tint" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.2" />
            </TableRow>
            <TableRow
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Space
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.2" />

                <TextView
                    android:id="@+id/tvInstallerTransferProgress"
                    android:layout_width="0dp"
                    android:layout_weight="0.2"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@android:color/white"
                    android:textSize="@dimen/records_table_cell_text_size"
                    android:layout_marginTop="@dimen/dimen_16x"
                    android:gravity="center|left" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.1" />

                <TextView
                    android:id="@+id/tvInstallerMessage"
                    android:layout_width="0dp"
                    android:layout_weight="0.5"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@android:color/white"
                    android:textSize="@dimen/records_table_cell_text_size"
                    android:layout_marginTop="@dimen/dimen_16x"
                    android:gravity="center|right" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.2" />
            </TableRow>

        </LinearLayout>

        <include
            android:id="@+id/inclBottomBar"
            layout="@layout/bottom_bar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/bottom_bar_height"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>
