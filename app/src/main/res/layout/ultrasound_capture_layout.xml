<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/ultrasound_capture_layout"
    android:layout_width="400dp"
    android:layout_height="400dp"
    android:background="@drawable/border_capture"
    android:orientation="horizontal">

    <ImageView
        android:id="@+id/ultrasound_capture_icon"
        android:layout_width="@dimen/capture_header_footer_height"
        android:layout_height="@dimen/capture_header_footer_height"
        android:layout_marginStart="0dp"
        android:layout_marginEnd="5dp"
        android:contentDescription="@string/ultrasound_capture_title"
        android:padding="2dp"
        android:src="@drawable/ultrasound" />

    <!--<TextView
        android:id="@+id/ultrasound_capture_id"
        android:layout_width="32dp"
        android:layout_height="@dimen/capture_header_footer_height"
        android:gravity="center"
        android:text="@string/intrav_capture_number"
        android:textColor="@color/white"
        android:textSize="@dimen/capture_id_text_size"
        android:textStyle="bold" />-->

    <TextView
        android:id="@+id/ultrasound_capture_header_label"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/capture_header_footer_height"
        android:layout_toEndOf="@id/ultrasound_capture_icon"
        android:text="@string/ultrasound_capture_label"
        android:textColor="@color/black"
        android:textSize="@dimen/capture_text_size"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/ultrasound_capture_measured_length"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/capture_header_footer_height"
        android:layout_alignParentEnd="true"
        android:layout_marginStart="10dp"
        android:paddingStart="10dp"
        android:paddingEnd="5dp"
        android:text=""
        android:textColor="@color/black"
        android:textSize="@dimen/capture_text_size"
        android:textStyle="bold" />

    <ImageView
        android:id="@+id/ultrasound_capture_image"
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:layout_below="@id/ultrasound_capture_header_label"        
        android:layout_margin="10dp"        
        android:background="@color/ap_transparent"
        app:backgroundColor="@color/ap_transparent"
        android:layout_marginTop="0dp"
        android:scaleType="fitXY"        
        />

    <TextView
        android:id="@+id/ultrasound_capture_footer_label"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/capture_header_footer_height"
        android:layout_alignParentBottom="true"
        android:layout_toEndOf="@id/ultrasound_capture_icon"
        android:text=""
        android:textColor="@color/black"
        android:textSize="@dimen/capture_text_size"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/ultrasound_capture_exposed_length"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/capture_header_footer_height"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="10dp"
        android:paddingStart="0dp"
        android:paddingEnd="5dp"
        android:text=""
        android:textColor="@color/black"
        android:textSize="@dimen/capture_text_size"
        android:textStyle="bold" />

</RelativeLayout>