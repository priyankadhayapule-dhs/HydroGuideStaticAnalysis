<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/card_bg">

    <ImageButton
        android:id="@+id/buttonCloseLicense"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:background="@drawable/button_outline_bg"
        android:padding="12dp"
        android:contentDescription="Close"
        android:elevation="2dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

    <TextView
        android:id="@+id/dialogTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="License &amp; Copyright Information"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/av_light_blue"
        android:gravity="center"
        android:layout_marginBottom="16dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginBottom="16dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="400dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textViewDialogCopyright"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="© 2024 Access Vascular Inc.\nAll rights reserved."
                android:textSize="14sp"
                android:textColor="@color/white"
                android:gravity="center"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/textViewDialogLicense"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/proprietary_text"
                android:textSize="12sp"
                android:textColor="#CCCCCC"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/textViewDialogVersion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Version 1.0.0"
                android:textSize="12sp"
                android:textColor="#AAAAAA"
                android:gravity="center"
                android:layout_marginBottom="8dp"/>
        </LinearLayout>
    </ScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"/>

    </LinearLayout>
</FrameLayout>
