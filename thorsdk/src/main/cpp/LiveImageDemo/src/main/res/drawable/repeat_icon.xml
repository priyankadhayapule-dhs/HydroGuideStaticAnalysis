<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false"
          android:drawable="@drawable/repeat_disabled" /> <!-- disabled -->
    <item android:state_checked="true"
          android:drawable="@drawable/repeat_checked" /> <!-- checked -->
    <item android:state_checked="false"
          android:drawable="@drawable/repeat_unchecked" /> <!-- unchecked -->
    <item android:drawable="@drawable/repeat_unchecked" /> <!-- default -->
</selector>
