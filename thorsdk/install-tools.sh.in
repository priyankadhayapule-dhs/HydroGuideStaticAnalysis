#!/bin/bash

# This is a self-installing package of the Thor binary utilities. To install,
# run this script with an attached Thor tablet. The utilities will be installed
# to the path /data/local/thortools

tempdir=$(mktemp -d 2>/dev/null || mktemp -d -t 'self-extract-tmp')

if [[ ! -d "$tempdir" ]]; then
	echo "Failed to create temporary directory."
	exit 1
fi

# See https://www.linuxjournal.com/content/add-binary-payload-your-shell-scripts
# Slightly modified to use base64 encoded data
function extract_payload()
{
	match=$(grep --text --line-number '^PAYLOAD:$' "$0" | cut -d ':' -f 1)
	payload=$((match + 1))

	case "$(uname -s)" in
		Linux*)     B64FLAG=-d;;
		Darwin*)    B64FLAG=-D;;
		*)          echo "Unsupported OS" && exit 1
	esac


	tail -n +$payload "$0" | base64 $B64FLAG | tar -xzf - -C "$tempdir"
}

extract_payload
adb shell mkdir -p /data/local/thortools
adb push --sync "$tempdir"/* /data/local/thortools

echo "Install complete"
rm -rf "$tempdir"
exit 0
PAYLOAD:
